#program4:Student Management System
students = []
while True:
    print("\n1 Add Student")
    print("2 Search Student")
    print("3 Delete Student")
    print("4 Exit")
    choice = input("Enter choice: ")
    if choice == "1":
        roll = input("Enter Roll No: ")
        name = input("Enter Name: ")
        marks = input("Enter Marks: ")
        students.append([roll, name, marks])
        print("Student Added")
    elif choice == "2":
        roll = input("Enter Roll No to search: ")
        found = False
        for s in students:
            if s[0] == roll:
                print("Roll:", s[0])
                print("Name:", s[1])
                print("Marks:", s[2])
                found = True
        if not found:
            print("Student not found")
    elif choice == "3":
        roll = input("Enter Roll No to delete: ")
        for s in students:
            if s[0] == roll:
                students.remove(s)
                print("Student Deleted")
                break
    elif choice == "4":
        print("Program Ended")
        break
  
        
